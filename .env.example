# ==============================================================================
# ExperimentIQ — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL Connection
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=experimentiq_db
DB_USER=experimentiq
DB_PASSWORD=experimentiq_password

# Full DSN (alternative — if set, overrides individual DB_* variables)
# DATABASE_URL=postgresql://experimentiq:experimentiq_password@localhost:5432/experimentiq_db

# ------------------------------------------------------------------------------
# Data Generation
# ------------------------------------------------------------------------------
# Total number of simulated users
GENERATOR_NUM_USERS=500000

# Experiment duration in days
GENERATOR_EXPERIMENT_DAYS=90

# Baseline purchase conversion rate for the control group (0.0 – 1.0)
GENERATOR_BASELINE_CONVERSION_RATE=0.035

# Variant uplift as relative percentage increase (e.g., 0.15 = 15% relative lift)
GENERATOR_VARIANT_UPLIFT=0.15

# Random seed for reproducibility
GENERATOR_RANDOM_SEED=42

# Percentage of users in the variant group (remainder in control)
GENERATOR_VARIANT_SPLIT=0.50

# Experiment start date (ISO 8601 format)
GENERATOR_EXPERIMENT_START_DATE=2024-01-01

# Maximum events per session
GENERATOR_MAX_EVENTS_PER_SESSION=20

# Average sessions per user
GENERATOR_AVG_SESSIONS_PER_USER=2.5

# ------------------------------------------------------------------------------
# Statistical Analysis
# ------------------------------------------------------------------------------
# Significance level (alpha)
STATS_ALPHA=0.05

# Target statistical power
STATS_POWER_TARGET=0.80

# Minimum Detectable Effect (absolute difference in conversion rate)
STATS_MDE=0.003

# Multiple testing correction method: bonferroni | benjamini_hochberg | none
STATS_CORRECTION_METHOD=benjamini_hochberg

# SRM chi-square threshold (default: 0.01)
STATS_SRM_ALPHA=0.01

# ------------------------------------------------------------------------------
# Recommendation Engine
# ------------------------------------------------------------------------------
# Minimum relative uplift required to recommend LAUNCH (e.g., 0.05 = 5%)
RECOMMENDATION_MIN_PRACTICAL_UPLIFT=0.05

# Guardrail metric tolerance: max acceptable degradation (e.g., 0.02 = 2%)
RECOMMENDATION_GUARDRAIL_TOLERANCE=0.02

# ------------------------------------------------------------------------------
# Output Paths (relative to project root)
# ------------------------------------------------------------------------------
OUTPUT_DATA_RAW_DIR=data/raw
OUTPUT_DATA_PROCESSED_DIR=data/processed
OUTPUT_DATA_EXPORTS_DIR=data/exports
OUTPUT_REPORTS_DIR=data/reports

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output file path (relative to project root). Leave empty to disable file logging.
LOG_FILE=data/logs/pipeline.log

# Use rich console output (true/false)
LOG_USE_RICH=true

# ------------------------------------------------------------------------------
# Performance
# ------------------------------------------------------------------------------
# Chunk size for bulk database inserts
DB_BULK_INSERT_CHUNK_SIZE=10000

# Number of rows to read from DB per analytics query fetch
ANALYTICS_FETCH_CHUNK_SIZE=50000
